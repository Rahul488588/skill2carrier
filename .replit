modules = ["java-graalvm22.3"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "java -jar gradle/wrapper/gradle-wrapper.jar :server:installDist --no-daemon && server/build/install/server/bin/server"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "server/build/install/server/bin/server"]
build = ["bash", "-c", "chmod +x gradlew && java -jar gradle/wrapper/gradle-wrapper.jar :server:installDist --no-daemon"]
